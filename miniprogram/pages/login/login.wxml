<view class="login-page">
  <view class="deco-circle deco-1"></view>
  <view class="deco-circle deco-2"></view>
  <view class="deco-circle deco-3"></view>
  <view class="deco-circle deco-4"></view>

  <view class="logo-section fade-in-scale">
    <view class="logo-dual">
      <view class="logo-half warm"><text class="logo-emoji">👴</text><text class="logo-label">守护</text></view>
      <view class="logo-divider"></view>
      <view class="logo-half cool"><text class="logo-emoji">👨‍👩‍👧</text><text class="logo-label">关爱</text></view>
    </view>
    <text class="app-name">安心守护</text>
    <text class="app-slogan">AI 驱动的智慧养老陪伴平台</text>
  </view>

  <view class="role-section">
    <button class="role-btn warm-btn fade-in-up" bindtap="selectElderly">
      <view class="rb-left"><text class="rb-emoji">👴</text><view class="rb-text"><text class="rb-name">我是长辈</text><text class="rb-sub">大字模式 · 语音播报 · 一键求救</text></view></view>
      <text class="rb-arrow">→</text>
    </button>
    <button class="role-btn cool-btn fade-in-up" style="animation-delay:0.12s" bindtap="selectFamily">
      <view class="rb-left"><text class="rb-emoji">👨‍👩‍👧</text><view class="rb-text"><text class="rb-name">我是家人</text><text class="rb-sub">实时监护 · AI分析 · 健康周报</text></view></view>
      <text class="rb-arrow">→</text>
    </button>
  </view>
  <text class="footer-text">守护每一份关爱</text>
</view>
