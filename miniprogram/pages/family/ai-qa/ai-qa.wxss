.qa-page { min-height: 100vh; background: var(--bg); display: flex; flex-direction: column; }

.suggest-bar { padding: 18rpx 24rpx 8rpx; }
.suggest-title { font-size: 24rpx; color: var(--text-secondary); display: block; margin-bottom: 10rpx; }
.suggest-chips { display: flex; flex-wrap: wrap; gap: 10rpx; }
.suggest-chip {
  padding: 10rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--primary);
  border: 1rpx solid var(--border);
}
.suggest-chip:active { background: var(--primary-bg); }

.chat-list { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; }
.qa-item { display: flex; margin-bottom: 24rpx; }
.qa-bot { align-items: flex-start; }
.qa-user { justify-content: flex-end; }

.qa-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0; margin-right: 10rpx;
  background: var(--primary-bg);
}
.qa-user .qa-avatar { margin-right: 0; margin-left: 10rpx; background: var(--accent-bg); }

.qa-bubble {
  max-width: 78%;
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
}
.qa-bot .qa-bubble { background: #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.qa-user .qa-bubble { background: var(--primary); color: #fff; }

.qa-typing { display: flex; gap: 5rpx; padding: 8rpx 0; }
.qa-typing view { width: 10rpx; height: 10rpx; background: var(--text-hint); border-radius: 50%; animation: blink 1.4s infinite; }
.qa-typing view:nth-child(2) { animation-delay: 0.2s; }
.qa-typing view:nth-child(3) { animation-delay: 0.4s; }

.input-bar { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 20rpx; background: #fff; border-top: 1rpx solid var(--border); padding-bottom: calc(14rpx + env(safe-area-inset-bottom)); }
.input-field { flex: 1; height: 72rpx; background: var(--bg); border-radius: 36rpx; padding: 0 24rpx; font-size: 28rpx; }
.send-btn { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #fff; border: none; flex-shrink: 0; }
.send-btn::after { border: none; }

.disclaimer { text-align: center; padding: 20rpx; font-size: 22rpx; color: var(--text-hint); }
