.alerts-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #F5F7FA;
  transition: all 0.2s;
}

.filter-tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

/* 告警列表 */
.alert-list {
  padding: 0 20rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
  transition: all 0.2s;
}

.alert-item.critical {
  border-left: 6rpx solid #FF4D4F;
}

.alert-item.handled {
  opacity: 0.6;
}

.alert-left {
  margin-right: 20rpx;
}

.alert-icon {
  font-size: 44rpx;
}

.alert-center {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-header-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.alert-type {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.alert-level {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.alert-level.critical { background: #FFF1F0; color: #FF4D4F; }
.alert-level.warning { background: #FFFBE6; color: #FAAD14; }

.alert-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.alert-time {
  font-size: 22rpx;
  color: #BFBFBF;
}

.alert-right {
  margin-left: 16rpx;
}

.handle-btn {
  background: var(--primary);
  color: #fff;
  font-size: 22rpx;
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
}
