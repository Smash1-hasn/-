.msg-page { min-height: 100vh; background: var(--bg); padding-bottom: 40rpx; }

.msg-card {
  background: #fff;
  margin: 0 20rpx 16rpx;
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}
.msg-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.msg-from { font-size: 24rpx; color: var(--text-secondary); }
.msg-time { font-size: 22rpx; color: var(--text-hint); }
.msg-body { font-size: 30rpx; color: var(--text); line-height: 1.7; margin-bottom: 12rpx; }
.voice-msg {
  background: linear-gradient(135deg, #FFF8E1, #FFF3E0);
  border-radius: 16rpx; padding: 16rpx 20rpx;
  border-left: 4rpx solid #FF9800;
}
.msg-del { text-align: right; font-size: 22rpx; color: var(--danger); padding: 8rpx; }

.clear-btn {
  margin: 0 20rpx 16rpx; text-align: center;
  padding: 16rpx; font-size: 26rpx; color: #E53935;
  background: #FFF5F5; border-radius: 14rpx;
}

.add-btn {
  margin: 28rpx 20rpx 8rpx;
  height: 88rpx;
  background: #fff;
  border-radius: var(--radius);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: var(--primary);
  border: 2rpx dashed var(--border);
}

.form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: flex-end; }
.form-panel { width: 100%; background: #fff; border-radius: 36rpx 36rpx 0 0; padding: 36rpx 32rpx; padding-bottom: calc(36rpx + env(safe-area-inset-bottom)); }
.fp-title { font-size: 34rpx; font-weight: 700; text-align: center; margin-bottom: 28rpx; }
.fp-textarea { width: 100%; height: 200rpx; background: var(--bg); border-radius: var(--radius-sm); padding: 20rpx; font-size: 30rpx; box-sizing: border-box; }
.fp-count { text-align: right; font-size: 22rpx; color: var(--text-hint); margin: 8rpx 0 24rpx; }
.fp-actions { display: flex; gap: 16rpx; }
.fp-cancel, .fp-send { flex: 1; text-align: center; padding: 20rpx 0; border-radius: var(--radius-sm); font-size: 30rpx; border: none; }
.fp-cancel { background: var(--bg); color: var(--text-secondary); }
.fp-send { background: var(--primary); color: #fff; }
