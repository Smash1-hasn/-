.rem-page { min-height: 100vh; background: var(--bg); padding-bottom: 40rpx; }

.tip-card {
  background: linear-gradient(135deg, #FFF8EE, #FFF3E0);
  margin: 20rpx;
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.tip-icon { font-size: 48rpx; }
.tip-text { flex: 1; font-size: 24rpx; color: #E65100; line-height: 1.6; }

.r-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  margin: 0 20rpx 12rpx;
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}
.r-switch { flex-shrink: 0; }
.r-info { flex: 1; }
.r-name { font-size: 30rpx; font-weight: 700; display: block; margin-bottom: 4rpx; }
.r-detail { font-size: 24rpx; color: var(--text-secondary); }
.r-time {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--primary);
  flex-shrink: 0;
  margin-right: 12rpx;
}
.r-del { font-size: 24rpx; color: var(--danger); padding: 8rpx; flex-shrink: 0; }

.add-btn {
  margin: 28rpx 20rpx;
  height: 88rpx;
  background: #fff;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--primary);
  border: 2rpx dashed var(--border);
}

.form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: flex-end; }
.form-panel { width: 100%; background: #fff; border-radius: 36rpx 36rpx 0 0; padding: 36rpx 32rpx; padding-bottom: calc(36rpx + env(safe-area-inset-bottom)); }
.fp-title { font-size: 34rpx; font-weight: 700; text-align: center; margin-bottom: 28rpx; }
.fp-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.fp-label { width: 120rpx; font-size: 28rpx; color: var(--text-secondary); flex-shrink: 0; }
.fp-input { flex: 1; background: var(--bg); border-radius: 12rpx; padding: 18rpx 20rpx; font-size: 28rpx; }
.fp-actions { display: flex; gap: 16rpx; margin-top: 28rpx; }
.fp-cancel, .fp-save { flex: 1; text-align: center; padding: 20rpx 0; border-radius: var(--radius-sm); font-size: 30rpx; border: none; }
.fp-cancel { background: var(--bg); color: var(--text-secondary); }
.fp-save { background: var(--primary); color: #fff; }

/* 联想下拉 */
.med-suggestions {
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin: -8rpx 0 12rpx 132rpx;
  overflow: hidden;
}
.med-sug-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #F5F0EB;
}
.med-sug-item:last-child { border-bottom: none; }
.med-sug-item:active { background: #EDF2F9; }
.sug-name { font-size: 28rpx; color: #2C3E50; }
.sug-dosage { font-size: 24rpx; color: #7F8C8D; background: #F5F0EB; padding: 2rpx 12rpx; border-radius: 8rpx; }
