.report-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 60rpx;
}

/* 服务网格 */
.service-grid {
  display: flex;
  gap: 12rpx;
  margin: 0 20rpx 20rpx;
}
.service-item {
  flex: 1;
  background: #fff;
  border-radius: var(--radius);
  padding: 24rpx 8rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}
.service-item:active { transform: scale(0.95); }
.svc-icon { font-size: 40rpx; display: block; margin-bottom: 6rpx; }
.svc-name { font-size: 22rpx; color: var(--text-secondary); }

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  margin: 20rpx;
  padding: 28rpx 32rpx;
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}
.user-avatar { font-size: 52rpx; }
.user-info { flex: 1; }
.user-name { font-size: 32rpx; font-weight: 700; display: block; }
.user-sub { font-size: 24rpx; color: var(--text-secondary); }
.user-gear { font-size: 36rpx; padding: 8rpx; }

/* 生成卡片 */
.gen-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 0 20rpx 20rpx;
  border-radius: var(--radius);
  padding: 36rpx;
  text-align: center;
  color: #fff;
}
.gen-title { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.gen-desc { font-size: 24rpx; opacity: 0.8; display: block; margin-bottom: 24rpx; }
.gen-btn { background: rgba(255,255,255,0.95); color: #667eea; }

/* 报告卡片 */
.report-card {
  background: #fff;
  margin: 0 20rpx 24rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow);
}
.report-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.report-date { font-size: 28rpx; font-weight: 600; color: var(--text); }

.report-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.risk-low { background: #F0FFF0; color: #2E7D32; }
.risk-mid { background: #FFF8EE; color: #E65100; }
.risk-high{ background: #FFF5F5; color: #C62828; }

.report-summary {
  background: var(--primary-bg);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
  text-align: center;
}

/* 指标网格 */
.metric-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.metric {
  flex: 1;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 20rpx 8rpx;
  text-align: center;
}
.metric-val { font-size: 36rpx; font-weight: 800; color: var(--text); display: block; }
.metric-lbl{ font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

/* 分析区 */
.report-section { margin-bottom: 20rpx; }
.report-section:last-child { margin-bottom: 0; }
.section-label { font-size: 26rpx; font-weight: 700; color: var(--text); display: block; margin-bottom: 8rpx; }
.section-content{ font-size: 28rpx; color: var(--text); line-height: 1.8; }

/* 历史 */
.history { margin: 0 20rpx; }
.history-title { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.history-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}
.hi-date { flex: 1; font-size: 26rpx; color: var(--text); }
.hi-badge {
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.hi-ago { font-size: 22rpx; color: var(--text-hint); }
