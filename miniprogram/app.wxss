/* ========================================
   安心守护 — 全局样式 v3.0
   主题: 温暖守护 Warm Guardian
   全链路升级：骨架屏/动画/空状态/加载态
   ======================================== */

page {
  /* 品牌色板 */
  --primary: #2B6CB0;
  --primary-dark: #1A4F8A;
  --primary-light: #5B9BD5;
  --primary-bg: #EDF2F9;
  --accent: #E8734A;
  --accent-light: #F0A080;
  --accent-bg: #FFF5F0;
  --success: #4CAF50;
  --success-bg: #F0FFF0;
  --warning: #FF9800;
  --warning-bg: #FFF8EE;
  --danger: #E53935;
  --danger-bg: #FFF5F5;
  --bg: #F5F0EB;
  --card: #FFFFFF;
  --text: #2C3E50;
  --text-secondary: #7F8C8D;
  --text-hint: #B0B8BF;
  --border: #E8E3DE;
  --shadow-sm: 0 2rpx 12rpx rgba(44,62,80,0.04);
  --shadow: 0 4rpx 20rpx rgba(44,62,80,0.07);
  --shadow-lg: 0 8rpx 32rpx rgba(44,62,80,0.10);
  --radius-sm: 12rpx;
  --radius: 20rpx;
  --radius-lg: 28rpx;
  --radius-full: 999rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ==================== 通用卡片 ==================== */
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}
.card:active { transform: scale(0.985); }
.card-flat {
  background: var(--card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 20rpx;
}

/* ==================== 按钮系统 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}
.btn::after { border: none; }
.btn:active { transform: scale(0.96); opacity: 0.85; }

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(43,108,176,0.25);
}

.btn-accent {
  background: linear-gradient(135deg, var(--accent) 0%, #D0623A 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(232,115,74,0.25);
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger) 0%, #C62828 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(229,57,53,0.25);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-ghost {
  background: var(--primary-bg);
  color: var(--primary);
}

/* ==================== 骨架屏 ==================== */
.skeleton {
  background: linear-gradient(90deg, #E8E3DE 25%, #F0EDE8 50%, #E8E3DE 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-line { height: 28rpx; margin-bottom: 16rpx; }
.skeleton-line:last-child { width: 60%; }
.skeleton-card { height: 180rpx; }
.skeleton-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }
.skeleton-title { height: 40rpx; width: 50%; margin-bottom: 20rpx; }
.skeleton-value { height: 80rpx; width: 40%; margin: 0 auto 20rpx; }

/* ==================== 加载态 ==================== */
.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}
.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 28rpx;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ==================== 数值展示 ==================== */
.value-large {
  font-size: 72rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  letter-spacing: -2rpx;
}
.value-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 6rpx;
  font-weight: 500;
}

/* ==================== 状态标签 ==================== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
}
.tag-normal { background: var(--success-bg); color: var(--success); }
.tag-warning { background: var(--warning-bg); color: var(--warning); }
.tag-danger { background: var(--danger-bg); color: var(--danger); }

/* ==================== 提示条 ==================== */
.tip-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: var(--primary-bg);
  border-radius: var(--radius-sm);
  margin: 20rpx;
  font-size: 26rpx;
  color: var(--primary);
}
.tip-bar.warning { background: var(--warning-bg); color: var(--warning); }
.tip-bar.danger { background: var(--danger-bg); color: var(--danger); }

/* ==================== 分隔 ==================== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 16rpx 0;
}

/* ==================== Flex 工具 ==================== */
.flex-row    { display: flex; flex-direction: row; align-items: center; }
.flex-col    { display: flex; flex-direction: column; }
.flex-between{ display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1      { flex: 1; }
.flex-wrap   { display: flex; flex-wrap: wrap; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }

/* ==================== 间距 ==================== */
.mt-8  { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-8  { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-20  { padding: 20rpx; }
.p-32  { padding: 32rpx; }

/* ==================== 文字 ==================== */
.text-center    { text-align: center; }
.text-secondary { color: var(--text-secondary); }
.text-hint      { color: var(--text-hint); }
.text-sm        { font-size: 24rpx; }
.text-base      { font-size: 28rpx; }
.text-lg        { font-size: 36rpx; }
.text-xl        { font-size: 44rpx; }
.font-bold      { font-weight: 700; }
.font-extrabold { font-weight: 800; }
.text-primary   { color: var(--primary); }
.text-accent    { color: var(--accent); }
.text-success   { color: var(--success); }
.text-warning   { color: var(--warning); }
.text-danger    { color: var(--danger); }

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  14% { transform: scale(1.3); }
  28% { transform: scale(1); }
  42% { transform: scale(1.3); }
  56% { transform: scale(1); }
}
@keyframes ripple {
  to { transform: scale(4); opacity: 0; }
}

.fade-in      { animation: fadeIn 0.35s ease-out; }
.fade-in-up   { animation: fadeInUp 0.5s ease-out; }
.fade-in-scale{ animation: fadeInScale 0.3s ease-out; }

/* 逐项动画延迟 */
.stagger-item:nth-child(1) { animation-delay: 0s; }
.stagger-item:nth-child(2) { animation-delay: 0.08s; }
.stagger-item:nth-child(3) { animation-delay: 0.16s; }
.stagger-item:nth-child(4) { animation-delay: 0.24s; }
.stagger-item:nth-child(5) { animation-delay: 0.32s; }

/* ==================== Section ==================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

/* ==================== 数字跳动动画 ==================== */
@keyframes countUp {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.count-up {
  animation: countUp 0.5s ease-out;
}
